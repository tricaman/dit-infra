# ── Domains & TLS ──────────────────────────────────────────────────────────
# Sottodomini su cui Caddy emette TLS automatica (Let's Encrypt).
# Devono già puntare via DNS al droplet PRIMA del primo `up -d` di caddy.
DOMAIN_API=dit-api.mariustrica.com
DOMAIN_WS=dit-ws.mariustrica.com
# Email per notifiche di rinnovo Let's Encrypt
ACME_EMAIL=you@mariustrica.com

# ── GHCR (GitHub Container Registry) ───────────────────────────────────────
# Username GitHub sotto cui vengono pushate le immagini ghcr.io/<USER>/<repo>
GHCR_USER=tricaman
# Tag delle immagini da deployare (default: latest). Per pinning usa SHA o version.
DIT_API_TAG=latest
DIT_PING_TAG=latest
DIT_WORKER_TAG=latest

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=dit
# IMPORTANTE: cambia questa password — non lasciare il default
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=dit

# ── JWT (condiviso tra dit-api e dit-ping) ─────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_SECRET=change_me_minimum_32_characters_long

# ── BetterAuth ─────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_minimum_32_characters_long
# Origini consentite separate da virgola (mobile uses scheme dit://)
TRUSTED_ORIGINS=dit://,https://dit-api.mariustrica.com

# ── Brevo (email transazionali) ────────────────────────────────────────────
BREVO_API_KEY=xkeysib-your-api-key
BREVO_SENDER_EMAIL=noreply@mariustrica.com

# ── OAuth providers ────────────────────────────────────────────────────────
# Redirect URI da configurare nei provider:
#   https://dit-api.mariustrica.com/auth/callback/google
#   https://dit-api.mariustrica.com/auth/callback/facebook
#   https://dit-api.mariustrica.com/auth/callback/microsoft
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Firebase Admin SDK (push notifications) ────────────────────────────────
# Incolla l'intero JSON del service account su una sola riga (escapa newline come \n)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── dit-ping tuning (opzionali) ────────────────────────────────────────────
PING_DEFAULT_TTL_SECONDS=3600
PING_MAX_TTL_SECONDS=86400
HUB_MAX_CONNECTIONS_PER_USER=5
AUTH_TIMEOUT_SECONDS=5
HEARTBEAT_INTERVAL_SECONDS=30
HEARTBEAT_TIMEOUT_SECONDS=60
BULL_QUEUE_NAME=notif

# ── dit-worker tuning ──────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
